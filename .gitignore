.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Debug and profiling
*.profraw
*.profdata

# Local runtime artifacts (Unix sockets, audit logs from demos)
/tmp/

# Cursor / editor local state
.cursor/
